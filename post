        }

        .content {
            padding: 32px 36px 40px 36px;
            flex: 1;
        }

        .title-section {
            text-align: center;
            margin-bottom: 24px;
            border-bottom: 3px solid #2c3e8f;
            padding-bottom: 16px;
        }
        .main-title {
