        }
        .card-title {
            font-size: 18px;
            font-weight: 700;
            color: #0f2b6d;
            border-left: 4px solid #3b82f6;
            padding-left: 12px;
            margin-bottom: 14px;
        }
        .card-text {
            font-size: 13px;
            line-height: 1.45;
            color: #1e293b;
            text-align: justify;
        }
        .metric-list {
            display: flex;
            flex-wrap: wrap;
            gap: 8px;
            margin-top: 12px;
        }
        .metric-badge {
            background: #e0f2fe;
            border-radius: 40px;
